public class StringPractice {
    public static void main(String[] args) {

        System.out.println("My first Java program");

        String a = "Keshav";
        String b = "Pal";

        System.out.println("Length of a: " + a.length());
        System.out.println("Full Name: " + a + " " + b);
        System.out.println("Uppercase: " + a.toUpperCase());
        System.out.println("Lowercase: " + b.toLowerCase());
        System.out.println("Substring of a: " + a.substring(1, 4));
        System.out.println("Are both same? " + a.equals(b));
        System.out.println("Character at index 2: " + a.charAt(2));
    }
}
